# .gitignore

# Sqlite
db.sqlite3

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*,cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Jupyter Notebook
.ipynb_checkpoints

# Django
staticfiles/
media/
static/

# Environment
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Sphinx documentation
docs/_build/

# PyBuilder
target/

# pyenv
.python-version

# Custom
bin/
*.csv
*.log
log/
tmp/
settings/

# Gunicorn
run/
.gunicorn

### JetBrains
.idea/
*.swp

# Custom
output/
test_output/

# Keep example JSON files, ignore actual data files
!input/*-example.json
input/movie-list*.json
!input/test-*.json
